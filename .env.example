# Auto-SignIn 环境变量配置示例
# 复制此文件为 .env 并填入您的实际配置

# ===================
# 调试模式
# ===================
AUTOSIGNIN_DEBUG=false

# ===================
# 定时任务
# ===================
AUTOSIGNIN_SCHEDULE=false
AUTOSIGNIN_SCHEDULE_TIME=08:00

# ===================
# 通知系统
# ===================
AUTOSIGNIN_NOTIFICATION=false

# ===================
# Telegram 通知配置
# ===================
# 在 @BotFather 创建机器人获取 Token
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===================
# 邮件通知配置
# ===================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
TO_EMAIL=receive_email@gmail.com

# ===================
# Webhook 通知配置
# ===================
WEBHOOK_URL=
WEBHOOK_METHOD=POST

# ===================
# 平台 Cookie（GitHub Actions 使用）
# ===================
# 在对应平台登录后通过 F12 获取 Cookie
NETEASE_COOKIES=
BILIBILI_COOKIES=
CSDN_COOKIES=
TAOBAO_COOKIES=
JD_COOKIES=
MEITUAN_COOKIES=
ALIPAY_COOKIES=
